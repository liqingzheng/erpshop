    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "terser": "^5.46.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vite-plugin-compression2": "^2.5.3"
  },
  "dependencies": {
    "antd": "^6.3.5",
    "axios": "^1.15.0",
    "bootstrap-icons": "^1.13.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "zustand": "^5.0.12"
