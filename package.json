  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode dev",
    "build:dev": "tsc && vite build --mode dev",
    "build:sit": "tsc && vite build --mode sit",
    "build:uat": "tsc && vite build --mode uat",
